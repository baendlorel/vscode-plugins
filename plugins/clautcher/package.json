{
  "name": "clautcher",
  "displayName": "Clautcher",
  "description": "A VS Code extensions for clautcher in npm",
  "description_zh": "一个用 npm 包 Clautcher 的 VS Code 扩展版本",
  "version": "0.0.1",
  "purpose": "vscode-extension",
  "publisher": "KasukabeTsumugi",
  "engines": {
    "vscode": "^1.74.0"
  },
  "author": {
    "email": "futami16237@gmail.com",
    "name": "Kasukabe Tsumugi"
  },
  "categories": [
    "Other"
  ],
  "keywords": [],
  "license": "MIT",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": []
  },
  "scripts": {
    "lines": "clear && find ./src -type f \\( -name \"*.ts\" -o -name \"*.tsx\" -o -name \"*.js\" -o -name \"*.mjs\" -o -name \"*.cjs\" -o -name \"*.cpp\" -o -name \"*.h\" -o -name \"*.py\"  -o -name \"*.css\" -o -name \"*.rs\" -o -name \"*.rc\" \\) | xargs wc -l",
    "test-build": "vite build --mode development",
    "build": "vite build",
    "watch": "vite build --watch --mode development",
    "check": "tsc --noEmit -p tsconfig.build.json",
    "lint": "oxlint .",
    "pub": "vsce package -o ./bin --no-dependencies",
    "publish": "pnpm build && vsce publish"
  }
}