{
  "name": "colorful-titlebar",
  "displayName": "Colorful Titlebar",
  "description": "A VS Code extension that adds backgroundColor(generated by your project name) to the title bar",
  "description_zh": "一个可以自动计算标题栏颜色的 VS Code 扩展，计算依据是你的项目文件夹名称、目录或日期（可自选）",
  "version": "1.5.1",
  "purpose": "vscode-extension",
  "publisher": "KasukabeTsumugi",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "titlebar",
    "color",
    "theme",
    "project",
    "workspace",
    "customization"
  ],
  "homepage": "https://github.com/baendlorel/vscode-plugins/tree/main/plugins/colorful-titlebar#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/baendlorel/vscode-plugins.git",
    "directory": "plugins/colorful-titlebar"
  },
  "bugs": {
    "url": "https://github.com/baendlorel/vscode-plugins/issues"
  },
  "license": "MIT",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "colorful-titlebar.controlPanel",
        "title": "%command.controlPanel.title%",
        "category": "%extension.category%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "colorful-titlebar.akasha": {
          "type": "string",
          "default": ""
        }
      }
    }
  }
}