{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": false,
    "resolvePackageJsonImports": true,
    "declaration": false,
    "rootDir": "./src"
  },
  "include": ["./src/**/*.ts"],
  "exclude": ["./tests/**/*", "./plugins/**/*.ts", "node_modules", ".vscode-test"]
}
