{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "resolvePackageJsonImports": true,
    "declaration": false,
    "esModuleInterop": true,
    "strict": true,
    "types": ["node"],
    "outDir": "out",
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["./src/**/*.ts", "./tests/**/*.ts", "./scripts/**/*.ts"]
}
